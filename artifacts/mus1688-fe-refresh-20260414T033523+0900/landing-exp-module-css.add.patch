diff --git a/musu-bee/src/app/landing-exp/page.module.css b/musu-bee/src/app/landing-exp/page.module.css
new file mode 100644
index 00000000..f1ce5aa4
--- /dev/null
+++ b/musu-bee/src/app/landing-exp/page.module.css
@@ -0,0 +1,655 @@
+.page {
+  --musu-brown: var(--musu-color-brand-ink);
+  --musu-brown-deep: #1f1512;
+  --musu-yellow: var(--musu-color-brand-accent);
+  --musu-yellow-strong: #f3b737;
+  --musu-offwhite: var(--musu-color-brand-canvas);
+  --musu-ink: #191312;
+  --musu-muted: #66554f;
+  --musu-line: rgb(var(--musu-color-brand-ink-rgb) / 18%);
+
+  min-height: 100vh;
+  overflow-y: auto;
+  background:
+    radial-gradient(circle at 14% -8%, rgb(var(--musu-color-brand-accent-rgb) / 38%), transparent 42%),
+    radial-gradient(circle at 86% 0%, rgb(var(--musu-color-brand-ink-rgb) / 15%), transparent 38%),
+    linear-gradient(180deg, var(--musu-color-brand-canvas) 0%, #f7f0dc 46%, var(--musu-color-brand-canvas) 100%);
+  color: var(--musu-ink);
+  font-family: var(--font-body), "Pretendard", "Noto Sans KR", sans-serif;
+}
+
+.topBar {
+  position: sticky;
+  top: 0;
+  z-index: 40;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 18px;
+  padding: 18px 28px;
+  border-bottom: 1px solid var(--musu-line);
+  background: rgb(var(--musu-color-brand-canvas-rgb) / 86%);
+  backdrop-filter: blur(10px);
+}
+
+.brand {
+  text-decoration: none;
+  color: var(--musu-color-brand-ink);
+  font-size: 1.2rem;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  flex-wrap: wrap;
+  justify-content: flex-end;
+}
+
+.navLink {
+  color: var(--musu-muted);
+  text-decoration: none;
+  font-size: 0.87rem;
+  font-weight: 600;
+  padding: 8px 10px;
+  border-radius: 999px;
+  transition: color 180ms ease, background 180ms ease;
+}
+
+.navLink:hover {
+  color: var(--musu-color-brand-ink);
+  background: rgb(var(--musu-color-brand-ink-rgb) / 8%);
+}
+
+.navButton {
+  color: #22150f;
+  background: var(--musu-color-brand-accent);
+  text-decoration: none;
+  font-size: 0.86rem;
+  font-weight: 700;
+  padding: 10px 14px;
+  border-radius: 999px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 26%);
+  transition: transform 180ms ease, background 180ms ease;
+}
+
+.navButton:hover {
+  transform: translateY(-1px);
+  background: var(--musu-yellow-strong);
+}
+
+.main {
+  max-width: 1160px;
+  margin: 0 auto;
+  padding: 52px 24px 92px;
+  display: grid;
+  gap: 42px;
+}
+
+.hero {
+  display: grid;
+  grid-template-columns: minmax(320px, 1.1fr) minmax(320px, 0.9fr);
+  gap: 30px;
+  align-items: start;
+}
+
+.heroCopy {
+  display: grid;
+  gap: 16px;
+  animation: riseIn 620ms ease both;
+}
+
+.eyebrow {
+  font-size: 0.73rem;
+  font-weight: 700;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: var(--musu-color-brand-ink);
+}
+
+.heroTitle {
+  margin: 0;
+  font-family: var(--font-heading), "Pretendard", "Noto Sans KR", sans-serif;
+  font-size: clamp(2.2rem, 5vw, 3.9rem);
+  line-height: 1.04;
+  letter-spacing: -0.03em;
+  color: var(--musu-brown-deep);
+}
+
+.heroLead {
+  margin: 0;
+  max-width: 64ch;
+  font-size: 1.04rem;
+  line-height: 1.7;
+  color: #4b3a33;
+}
+
+.chipRow {
+  display: flex;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+
+.chip {
+  border-radius: 999px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 20%);
+  background: rgb(var(--musu-color-brand-canvas-rgb) / 80%);
+  color: #4e3d37;
+  padding: 8px 12px;
+  font-size: 0.78rem;
+  font-weight: 600;
+}
+
+.waitlistForm {
+  display: grid;
+  grid-template-columns: minmax(180px, 1fr) auto auto;
+  gap: 10px;
+  align-items: center;
+  margin-top: 6px;
+}
+
+.hiddenLabel {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  margin: -1px;
+  clip: rect(0, 0, 0, 0);
+  overflow: hidden;
+  white-space: nowrap;
+}
+
+.waitlistInput {
+  width: 100%;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 22%);
+  background: rgb(var(--musu-color-brand-canvas-rgb) / 98%);
+  color: var(--musu-ink);
+  border-radius: 12px;
+  padding: 12px 13px;
+  font-size: 0.95rem;
+  outline: none;
+}
+
+.waitlistInput:focus {
+  border-color: rgb(var(--musu-color-brand-ink-rgb) / 58%);
+  box-shadow: 0 0 0 3px rgb(var(--musu-color-brand-accent-rgb) / 28%);
+}
+
+.primaryCta {
+  border-radius: 12px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 24%);
+  background: var(--musu-color-brand-accent);
+  color: #20130f;
+  font-size: 0.9rem;
+  font-weight: 700;
+  letter-spacing: 0.02em;
+  padding: 12px 14px;
+  cursor: pointer;
+  text-decoration: none;
+  transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
+}
+
+.primaryCta:hover {
+  transform: translateY(-1px);
+  background: var(--musu-yellow-strong);
+  box-shadow: 0 10px 22px rgb(var(--musu-color-brand-ink-rgb) / 16%);
+}
+
+.primaryCtaLink {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.secondaryCta {
+  border-radius: 12px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 18%);
+  background: rgb(var(--musu-color-brand-canvas-rgb) / 72%);
+  color: #4e3c35;
+  font-size: 0.88rem;
+  font-weight: 600;
+  padding: 12px 14px;
+  text-decoration: none;
+  transition: background 180ms ease, border-color 180ms ease;
+}
+
+.secondaryCta:hover {
+  background: rgba(255, 255, 255, 0.98);
+  border-color: rgb(var(--musu-color-brand-ink-rgb) / 30%);
+}
+
+.okMessage,
+.errorMessage {
+  margin: 0;
+  font-size: 0.87rem;
+  font-weight: 600;
+}
+
+.okMessage {
+  color: #0c7a43;
+}
+
+.errorMessage {
+  color: #b4232e;
+}
+
+.benefitList {
+  list-style: none;
+  display: grid;
+  gap: 8px;
+  margin: 4px 0 0;
+  padding: 0;
+}
+
+.benefitItem {
+  border-radius: 12px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 14%);
+  background: rgba(255, 255, 255, 0.54);
+  padding: 10px 12px;
+  font-size: 0.87rem;
+  color: #4f3e37;
+}
+
+.heroVisual {
+  display: grid;
+  gap: 14px;
+  animation: riseIn 780ms ease both;
+}
+
+.runtimeBoard {
+  position: relative;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 20%);
+  border-radius: 20px;
+  background:
+    linear-gradient(160deg, rgb(var(--musu-color-brand-canvas-rgb) / 96%), rgba(255, 242, 209, 0.72)),
+    var(--musu-offwhite);
+  padding: 18px;
+  overflow: hidden;
+}
+
+.runtimeBoard::after {
+  content: "";
+  position: absolute;
+  inset: 0;
+  background: linear-gradient(
+    115deg,
+    transparent 14%,
+    rgb(var(--musu-color-brand-accent-rgb) / 16%) 36%,
+    transparent 56%
+  );
+  animation: sweep 3.8s ease-in-out infinite;
+  pointer-events: none;
+}
+
+.runtimeHeader {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 8px;
+}
+
+.runtimeTitle {
+  font-family: var(--font-heading), "Pretendard", "Noto Sans KR", sans-serif;
+  font-size: 0.93rem;
+  font-weight: 700;
+  color: var(--musu-brown-deep);
+}
+
+.runtimeMeta {
+  font-size: 0.73rem;
+  font-weight: 600;
+  color: #6d5a53;
+}
+
+.runtimeRows {
+  list-style: none;
+  margin: 16px 0 0;
+  padding: 0;
+  display: grid;
+  gap: 10px;
+}
+
+.runtimeRow {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 10px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 12%);
+  border-radius: 12px;
+  padding: 10px 12px;
+  background: rgba(255, 255, 255, 0.64);
+}
+
+.runtimeHost {
+  margin: 0;
+  font-size: 0.86rem;
+  font-weight: 700;
+  color: #2b201d;
+}
+
+.runtimeDuty {
+  margin: 2px 0 0;
+  font-size: 0.76rem;
+  color: #5d4b45;
+}
+
+.statePill {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-width: 58px;
+  padding: 7px 10px;
+  border-radius: 999px;
+  font-size: 0.68rem;
+  font-weight: 700;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.stateReady {
+  color: #0a7d54;
+  background: rgba(10, 125, 84, 0.12);
+}
+
+.stateBusy {
+  color: #8f5500;
+  background: rgb(var(--musu-color-brand-accent-rgb) / 30%);
+  animation: pulseBusy 1.8s ease-in-out infinite;
+}
+
+.commandRow {
+  display: block;
+  margin-top: 14px;
+  border-radius: 10px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 18%);
+  background: var(--musu-color-brand-ink);
+  color: var(--musu-color-brand-canvas);
+  padding: 9px 11px;
+  font-family: "JetBrains Mono", "Fira Code", monospace;
+  font-size: 0.75rem;
+  overflow: auto;
+}
+
+.heroAside {
+  border-radius: 18px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 16%);
+  background: rgba(255, 255, 255, 0.52);
+  padding: 16px;
+}
+
+.asideLabel {
+  margin: 0;
+  font-size: 0.74rem;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  font-weight: 700;
+  color: #6c5952;
+}
+
+.asideTitle {
+  margin: 6px 0 8px;
+  font-size: 1.08rem;
+  line-height: 1.25;
+  color: #2a1d19;
+}
+
+.asideBody {
+  margin: 0;
+  font-size: 0.88rem;
+  line-height: 1.65;
+  color: #4f3d37;
+}
+
+.referenceStrip {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  flex-wrap: wrap;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 16%);
+  border-radius: 14px;
+  background: rgba(255, 255, 255, 0.5);
+  padding: 13px 15px;
+}
+
+.referenceLead {
+  font-size: 0.84rem;
+  font-weight: 700;
+  color: #55433d;
+}
+
+.referenceList {
+  display: flex;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+
+.referenceChip {
+  border-radius: 999px;
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 20%);
+  padding: 7px 10px;
+  font-size: 0.76rem;
+  font-weight: 700;
+  color: #4e3c35;
+  background: rgba(255, 255, 255, 0.76);
+}
+
+.sectionBlock {
+  display: grid;
+  gap: 16px;
+}
+
+.sectionHeader {
+  display: grid;
+  gap: 6px;
+}
+
+.sectionEyebrow {
+  margin: 0;
+  font-size: 0.72rem;
+  font-weight: 700;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: #6f5c55;
+}
+
+.sectionTitle {
+  margin: 0;
+  font-size: clamp(1.5rem, 2.8vw, 2.2rem);
+  line-height: 1.14;
+  color: #2a1d18;
+}
+
+.cardGrid,
+.installGrid,
+.surfaceGrid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 14px;
+}
+
+.infoCard,
+.installCard,
+.surfaceCard {
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 16%);
+  border-radius: 16px;
+  background: rgba(255, 255, 255, 0.56);
+  padding: 16px;
+  display: grid;
+  gap: 8px;
+}
+
+.infoTitle,
+.installTitle,
+.surfaceTitle {
+  margin: 0;
+  font-size: 1.04rem;
+  line-height: 1.25;
+  color: #2b1f1a;
+}
+
+.infoBody,
+.installBody,
+.surfaceBody {
+  margin: 0;
+  font-size: 0.88rem;
+  line-height: 1.68;
+  color: #4d3c36;
+}
+
+.installPlatform,
+.installStatus,
+.surfaceMetric {
+  margin: 0;
+  font-size: 0.72rem;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  font-weight: 700;
+  color: #6d5a54;
+}
+
+.safetyBlock {
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 16%);
+  border-radius: 20px;
+  background:
+    linear-gradient(130deg, rgb(var(--musu-color-brand-ink-rgb) / 6%), rgb(var(--musu-color-brand-accent-rgb) / 14%)),
+    rgba(255, 255, 255, 0.54);
+  padding: 18px;
+  display: grid;
+  grid-template-columns: 1.1fr 0.9fr;
+  gap: 14px;
+  align-items: start;
+}
+
+.safetyList {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 8px;
+}
+
+.safetyItem {
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 15%);
+  border-radius: 12px;
+  background: rgb(var(--musu-color-brand-canvas-rgb) / 76%);
+  padding: 10px 12px;
+  font-size: 0.87rem;
+  color: #4c3b35;
+}
+
+.finalCta {
+  border: 1px solid rgb(var(--musu-color-brand-ink-rgb) / 18%);
+  border-radius: 20px;
+  background: var(--musu-color-brand-ink);
+  color: var(--musu-color-brand-canvas);
+  padding: 22px;
+  display: grid;
+  gap: 14px;
+}
+
+.finalTitle {
+  margin: 0;
+  font-size: clamp(1.42rem, 3.2vw, 2rem);
+  line-height: 1.2;
+}
+
+.finalActions {
+  display: flex;
+  gap: 10px;
+  flex-wrap: wrap;
+}
+
+.finalCta .secondaryCta {
+  color: var(--musu-color-brand-canvas);
+  background: rgba(255, 255, 255, 0.06);
+  border-color: rgba(255, 255, 255, 0.26);
+}
+
+.finalCta .secondaryCta:hover {
+  background: rgba(255, 255, 255, 0.16);
+}
+
+@keyframes sweep {
+  0% {
+    transform: translateX(-130%);
+  }
+  52% {
+    transform: translateX(118%);
+  }
+  100% {
+    transform: translateX(118%);
+  }
+}
+
+@keyframes riseIn {
+  from {
+    opacity: 0;
+    transform: translateY(16px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+@keyframes pulseBusy {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.6;
+  }
+}
+
+@media (max-width: 1040px) {
+  .hero {
+    grid-template-columns: 1fr;
+  }
+
+  .cardGrid,
+  .installGrid,
+  .surfaceGrid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .safetyBlock {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (max-width: 760px) {
+  .topBar {
+    padding: 14px 16px;
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .main {
+    padding: 32px 16px 72px;
+    gap: 32px;
+  }
+
+  .waitlistForm {
+    grid-template-columns: 1fr;
+  }
+
+  .cardGrid,
+  .installGrid,
+  .surfaceGrid {
+    grid-template-columns: 1fr;
+  }
+
+  .finalActions {
+    flex-direction: column;
+    align-items: stretch;
+  }
+
+  .finalActions a,
+  .finalActions button {
+    text-align: center;
+    justify-content: center;
+  }
+}
