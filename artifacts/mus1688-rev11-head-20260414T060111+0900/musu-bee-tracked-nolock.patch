+export function getPublicAppUrl(): string {
+  return process.env.NEXT_PUBLIC_APP_URL?.trim() || "http://localhost:3001";
+}
+
+export function getOAuthRedirectUrl(next = "/app"): string {
+  const base = getPublicAppUrl().replace(/\/+$/, "");
