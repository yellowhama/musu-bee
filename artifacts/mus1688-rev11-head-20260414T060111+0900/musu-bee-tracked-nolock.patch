-      }
-
-      const priceId = sub.items.data[0]?.price?.id ?? null;
-      const plan = tierFromPriceId(priceId);
-      if (!plan) {
-        ignoredReason = "unknown_price_id";
-        retryable = true;
-        break;
-      }
-
-      const status =
-        sub.status === "active" || sub.status === "trialing"
