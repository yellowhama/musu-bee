# Copy to ~/.musu/cleanup.env and edit. Keep this conservative.
#
# TTLs (days)
# MUSU_CLEANUP_LOGS_TTL_DAYS=7
# MUSU_CLEANUP_RUN_TTL_DAYS=3
# MUSU_CLEANUP_ARTIFACTS_TTL_DAYS=14
#
# Size caps (MB)
# MUSU_CLEANUP_LOGS_SIZE_CAP_MB=1024
# MUSU_CLEANUP_RUN_SIZE_CAP_MB=100
# MUSU_CLEANUP_ARTIFACTS_SIZE_CAP_MB=2048
#
# Safety: never delete files modified within last N minutes
# MUSU_CLEANUP_MIN_AGE_MINUTES=10

