# musu-bridge 환경변수 예시 (~/.musu/bridge.env 에 복사)

# [필수] Bridge API 인증 토큰 (openssl rand -hex 32 로 생성)
MUSU_BRIDGE_TOKEN=

# [선택] 허용 Origins (쉼표 구분, 기본: musu.pro + localhost)
# MUSU_BRIDGE_ALLOWED_ORIGINS=https://musu.pro,http://localhost:3001

# [선택] Bridge 포트 (기본: 8070)
# BRIDGE_PORT=8070

# [선택] 프로덕션 환경 표시
# MUSU_ENV=production

# [선택] DB 경로 (기본: ~/.musu/musu.db)
# MUSU_DB_PATH=/home/youruser/.musu/musu.db

# [선택] 최대 동시 태스크 수 (기본: 20)
# MUSU_MAX_CONCURRENT_TASKS=20

# [선택] musu.pro 클라우드 레지스트리 + relay 인증 토큰
# MUSU_TOKEN=

# [선택] Cloud relay tunnel — musu.pro/dashboard 원격 접속용 (유료)
# MUSU_RELAY_ENABLED=true
# MUSU_RELAY_URL=wss://musu-relay-production.up.railway.app

# [선택] CEO heartbeat 스케줄러 — 자율 회사 운영 (30분마다 CEO 깨우기)
# MUSU_CEO_HEARTBEAT_ENABLED=true
# MUSU_CEO_HEARTBEAT_INTERVAL=1800
# MUSU_CEO_AGENT_NAME=ceo
