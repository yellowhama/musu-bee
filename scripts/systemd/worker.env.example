# Copy to ~/.musu/worker.env and edit. Never commit secrets.
#
# For mesh / remote access:
# - Set MUSU_WORKER_HOST=0.0.0.0 only if you're on a trusted network (e.g. Tailscale)
# - Set MUSU_WORKER_TOKEN (or MUSU_WORKER_TOKEN_FILE) before exposing beyond localhost

# Network
# MUSU_WORKER_HOST=127.0.0.1
# MUSU_WORKER_PORT=9700

# Auth
# MUSU_WORKER_TOKEN=...                         # prefer file-based
# MUSU_WORKER_TOKEN_FILE=~/.musu/worker_token   # used by scripts/start-worker.sh

# Concurrency (keep small; this is a sidecar)
# MUSU_WORKER_MAX_CONCURRENT_RUNS=2
# MUSU_WORKER_CONCURRENCY_MODE=reject           # reject|wait
# MUSU_WORKER_CONCURRENCY_WAIT_TIMEOUT_SEC=2

# Output caps (bytes) to prevent OOM on huge outputs
# MUSU_WORKER_MAX_STDOUT_BYTES=2000000
# MUSU_WORKER_MAX_STDERR_BYTES=2000000

