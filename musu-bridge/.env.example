# musu-bridge configuration
# Copy to .env and customize. See docs/CONFIG.md for details.

# ── Required ─────────────────────────────────────────────────────────────────
MUSU_BRIDGE_TOKEN=          # Auto-generated by install.sh. Min 32 chars in production.

# ── Server ───────────────────────────────────────────────────────────────────
BRIDGE_HOST=0.0.0.0         # 0.0.0.0 for remote access, 127.0.0.1 for local only
BRIDGE_PORT=8070

# ── Node Identity ────────────────────────────────────────────────────────────
MUSU_NODE_NAME=             # Auto-detected from hostname if empty

# ── Cloud (musu.pro) ────────────────────────────────────────────────────────
# MUSU_TOKEN=               # Account token for peer discovery via musu.pro
# MUSU_RELAY_ENABLED=true   # Enable WebSocket relay tunnel
# MUSU_RELAY_URL=https://musu-relay-production.up.railway.app

# ── Heartbeats ───────────────────────────────────────────────────────────────
# MUSU_CEO_HEARTBEAT_ENABLED=false
# MUSU_CEO_HEARTBEAT_INTERVAL=1800
# MUSU_NODE_HEARTBEAT_ENABLED=true
# MUSU_NODE_HEARTBEAT_INTERVAL=300
# MUSU_TEAM_LEAD_HEARTBEAT_ENABLED=false

# ── Concurrency ──────────────────────────────────────────────────────────────
# MUSU_MAX_CONCURRENT_TASKS=20
# MUSU_CHANNEL_MAX_TASKS=5

# ── Worker ───────────────────────────────────────────────────────────────────
# MUSU_WORKER_HOST=0.0.0.0
# MUSU_WORKER_PORT=9700
# MUSU_WORKER_TOKEN=        # Same as MUSU_BRIDGE_TOKEN if not set
