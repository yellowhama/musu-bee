# musu-bridge environment configuration
# Copy to .env and fill in values. Never commit .env.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Token required in Authorization: Bearer header for all API calls.
# Set to the same value as your musu.pro node_token.
MUSU_BRIDGE_TOKEN=

# Comma-separated origins allowed for CORS (browser clients).
# Example: https://musu.pro,http://localhost:3001
MUSU_BRIDGE_ALLOWED_ORIGINS=https://musu.pro

# ── Cloud Registry (musu.pro) ─────────────────────────────────────────────────
# Token from musu.pro/account/tokens to register this node in the cloud registry.
# Enables remote peer discovery across networks (e.g. laptop ↔ desktop over internet).
# Leave empty to disable cloud registry (local-only / Tailscale pairing still works).
MUSU_TOKEN=

# Human-readable name for this node (shown in musu-bee UI). Defaults to hostname.
MUSU_NODE_NAME=

# Public URL advertised to peers via cloud registry. Use Tailscale IP or ngrok URL.
# Example: http://100.64.0.1:8070  or  https://my-node.ngrok.io
MUSU_BRIDGE_PUBLIC_URL=

# ── Network ───────────────────────────────────────────────────────────────────
# Host to bind. Use 127.0.0.1 (default) for localhost-only.
# Change to 0.0.0.0 for Tailscale / LAN exposure.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8070

# ── Wake-on-LAN ───────────────────────────────────────────────────────────────
# MAC address of this machine's primary network interface.
# Example: aa:bb:cc:dd:ee:ff
MUSU_MAC_ADDRESS=

# Broadcast IP for WoL magic packet (defaults to 255.255.255.255).
MUSU_BROADCAST_IP=255.255.255.255

# ── Worker ────────────────────────────────────────────────────────────────────
# URL of the musu-worker GPU/process execution service.
MUSU_WORKER_URL=http://127.0.0.1:9700

# Auth token for musu-worker (must match MUSU_WORKER_TOKEN on the worker).
MUSU_WORKER_TOKEN=

# ── QUIC proxy (musu-connectsd) ───────────────────────────────────────────────
# URL of the local musu-connectsd bridge-proxy sidecar.
# Set to empty string to disable QUIC and always use HTTP fallback.
MUSU_QUIC_PROXY_URL=http://127.0.0.1:9443

# ── Mesh ──────────────────────────────────────────────────────────────────────
# Name of this node in the mesh (used in nodes.toml as mesh.self).
MUSU_MESH_SELF=main-pc

# Path to nodes.toml (defaults to ~/.musu/nodes.toml).
# MUSU_NODES_TOML=~/.musu/nodes.toml

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the musu-core SQLite database file.
MUSU_DB_PATH=~/.musu/musu.db

# ── Concurrency ───────────────────────────────────────────────────────────────
# Maximum number of concurrent task executions (default: 20).
MUSU_MAX_CONCURRENT_TASKS=20

# ── Company / MCP ─────────────────────────────────────────────────────────────
# Canonical company ID used for MCP configuration and agent seeding.
# Copy from your Paperclip/musu setup. Leave empty to auto-generate.
PAPERCLIP_COMPANY_ID=

# ── Environment ───────────────────────────────────────────────────────────────
# Runtime environment. Set to "production" to enable stricter security checks.
# Options: production, development (default: development)
MUSU_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
