# Supabase — obtain from https://app.supabase.com/project/poyclapxmvulvboiebxq/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://poyclapxmvulvboiebxq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-side billing sync (webhook -> Supabase)
SUPABASE_URL=https://poyclapxmvulvboiebxq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: table/column overrides for webhook sync writes
SUPABASE_SUBSCRIPTION_TABLE=subscription_state
SUPABASE_SUBSCRIPTION_ROW_ID=default

# Chat backend routing
MUSU_PORT_URL=http://127.0.0.1:1355
MUSU_LLM_URL=http://127.0.0.1:11434
# Basic per-client chat limit (requests per minute, server-side)
MUSU_CHAT_RATE_LIMIT_PER_MINUTE=20
# Optional: leave empty to auto-discover via MUSU_LLM_URL/v1/models
# MUSU_LLM_MODEL=

# musu-bridge — chat history + agent message routing
MUSU_BRIDGE_URL=http://127.0.0.1:8070

# musu-worker — CLI execution (server-side only)
MUSU_WORKER_URL=http://127.0.0.1:9700
# musu-worker — client-side URL for direct WebSocket / fetch from browser
NEXT_PUBLIC_MUSU_WORKER_URL=http://127.0.0.1:9700

# Claude API key (required by musu-bridge for agent routing)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI CLI binary — used as final chat fallback (claude, codex, gemini, etc.)
# Leave unset to disable the CLI fallback.
# MUSU_AI_CLI=claude
#
# Args passed before the prompt (default: --print for Claude Code)
# Change for other CLIs: e.g. "-p" for Gemini CLI, "" for Codex
# MUSU_AI_CLI_ARGS=--print

# SQLite database paths (relative to musu-functions root by default)
MUSU_TASKS_DB=../tasks.db
MUSU_WIKI_DB=../wiki.db

# Paddle — obtain from https://vendors.paddle.com/ (Sandbox or Production)
PADDLE_API_KEY=your-paddle-api-key-here
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret-here
# Paddle.js client-side token (Paddle dashboard -> client-side token)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token-here
# Use "sandbox" for development, "production" for live
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Price IDs — obtain from Paddle dashboard
PADDLE_PRICE_ID_PRO=pri_...
PADDLE_PRICE_ID_TEAM=pri_...

# Public app URL (used for Paddle redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3001
