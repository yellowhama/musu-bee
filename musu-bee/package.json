{
  "name": "musu-bee",
  "version": "1.15.0-rc.22",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--disable-warning=ExperimentalWarning next build --webpack",
    "build:tauri-shell": "node scripts/build-tauri-shell.mjs",
    "build:tauri-sidecars": "node scripts/build-tauri-sidecars.mjs",
    "test:tauri-shell:artifact": "npm run build:tauri-shell && node scripts/verify-tauri-shell-build.mjs",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:tauri-shell": "tsx --test src-tauri-shell/cockpit-contract.test.ts",
    "test:tauri-shell:browser": "playwright test --config=playwright.tauri-shell.config.ts",
    "test:public-release": "tsx --test src/app/public-metadata-contract.test.ts src/app/install.ps1/route.test.ts src/app/repair-fleet.ps1/route.test.ts",
    "test:runtime-polling": "tsx --test src/app/runtime-polling-contract.test.ts",
    "test:routes": "tsx --test src/app/api/agents/route.test.ts src/app/api/account/mesh-bearer/route.test.ts src/app/api/device-status/route.test.ts src/app/api/nodes/execute/route.test.ts src/app/api/processes/route.test.ts src/app/api/processes/start/route.test.ts src/app/api/processes/kill/route.test.ts src/app/api/tasks/forward/route.test.ts src/app/api/rooms/[[]roomId[]]/work-orders/route.test.ts",
    "test:p2p": "tsx --test src/lib/p2pKvEnv.test.ts src/lib/meshBearer.test.ts src/app/api/v1/p2p/route-evidence/route.test.ts src/app/api/v1/p2p/rendezvous/route.test.ts src/app/api/rooms/[[]roomId[]]/rendezvous/route.test.ts src/app/api/rooms/[[]roomId[]]/events/route.test.ts src/app/api/rooms/[[]roomId[]]/presence/route.test.ts src/app/api/v1/p2p/relay/lease/route.test.ts src/app/api/v1/p2p/relay/transport/route.test.ts src/app/api/v1/p2p/relay/transport-proof/route.test.ts src/app/api/v1/p2p/relay/payload/route.test.ts src/app/api/v1/relay/connect/route.test.ts src/app/api/v1/relay/payload/route.test.ts",
    "test:vocab": "tsx --test src/lib/vocabulary-audit.test.ts",
    "test:webhooks": "tsx --test src/app/api/webhooks/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --config=playwright.ci.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth-landing": "bash ./scripts/run-auth-e2e-lane.sh 3003 false playwright.authlanding.config.ts e2e/auth-landing.spec.ts",
    "test:e2e:auth-guard": "bash ./scripts/run-auth-e2e-lane.sh 3002 true playwright.authguard.config.ts e2e/auth-landing.spec.ts -g @guard",
    "tauri": "tauri",
    "tauri:dev": "set TAURI_ENV=true&& tauri dev",
    "tauri:build": "set TAURI_ENV=true&& tauri build"
  },
  "dependencies": {
    "@paddle/paddle-js": "^1.6.2",
    "@streamoji/avatar-widget": "^0.7.5",
    "@supabase/supabase-js": "^2.102.1",
    "@tauri-apps/api": "^2.11.0",
    "@vercel/kv": "^3.0.0",
    "dompurify": "^3.4.5",
    "lucide-react": "^1.11.0",
    "next": "^16.2.7",
    "react": "^19",
    "react-arborist": "^3.7.0",
    "react-dom": "^19",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tldraw": "^5.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-attach": "^0.9.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
