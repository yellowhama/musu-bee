{
  "name": "musu-bee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:webhooks": "tsx --test src/app/api/webhooks/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth-landing": "bash ./scripts/run-auth-e2e-lane.sh 3003 false playwright.authlanding.config.ts e2e/auth-landing.spec.ts",
    "test:e2e:auth-guard": "bash ./scripts/run-auth-e2e-lane.sh 3002 true playwright.authguard.config.ts e2e/auth-landing.spec.ts -g @guard"
  },
  "dependencies": {
    "@paddle/paddle-js": "^1.6.2",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/kv": "^3.0.0",
    "next": "15.5.14",
    "react": "^19",
    "react-dom": "^19",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
