{
  "name": "musu-views",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:tasks": "vite build tasks --config vite.config.ts --outDir ../dist/tasks --emptyOutDir",
    "build:nodes": "vite build nodes --config vite.config.ts --outDir ../dist/nodes --emptyOutDir",
    "build": "npm run build:tasks && npm run build:nodes",
    "dev:tasks": "vite tasks --config vite.config.ts",
    "dev:nodes": "vite nodes --config vite.config.ts"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
