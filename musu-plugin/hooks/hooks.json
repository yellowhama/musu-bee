{
  "description": "Guard irreversible Paperclip control-plane actions with explicit confirmation tokens.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*__(pause_agent|resume_agent|resolve_approval|update_issue)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/paperclip_guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
