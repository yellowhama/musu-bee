#!/bin/sh
# musu-init — first-boot orchestrator for musu-backend.tar
# Path inside rootfs: /usr/local/bin/musu-init
# V23.2 Workstream B4a (wiki/370 §6.1)
#
# Orchestrates K3s → account_key wait → gateway in sequence with explicit
# readiness gates. Direct OpenRC auto-enabling of k3s + musu-gateway is
# forbidden (Critic C2 HIGH) because OpenRC's `need k3s` ensures "started"
# not "API Ready" — leading to gateway crash-loop on first boot.
#
# Exit codes:
#   0 — full stack up (K3s Ready + account_key present + gateway started)
#   1 — K3s never became Ready within MUSU_K3S_READY_TIMEOUT_SEC (default 180s)
#   2 — /etc/musu/account_key not present within MUSU_KEY_WAIT_TIMEOUT_SEC
#       (default 0 == wait forever; B4c sets this to fail-fast)
#
# Env overrides:
#   MUSU_K3S_READY_TIMEOUT_SEC  seconds to wait for K3s API Ready (default 180)
#   MUSU_KEY_WAIT_TIMEOUT_SEC   seconds to wait for /etc/musu/account_key
#                               (default 0 == wait forever, WARN every 30s)

set -e

# Idempotent first-boot initialization of OpenRC (no-op on subsequent boots).
# Critic C11 (LOW) resolution: rc-status > /dev/null first to detect whether
# OpenRC is already up.
rc-status >/dev/null 2>&1 || openrc default

# ── 1. Start K3s ───────────────────────────────────────────────────────────
echo "musu-init: starting K3s"
rc-service k3s start

# ── 2. Wait for K3s API Ready ──────────────────────────────────────────────
# Critic C8 (MED) resolution: 180s default (was 60s — too tight for first-boot
# airgap-image import on locked-down corporate laptops).
# Critic C12 (LOW) resolution: explicit K3S_READY flag + hard exit 1 on timeout
# (was a silent fall-through after 30 loop iterations).
TIMEOUT="${MUSU_K3S_READY_TIMEOUT_SEC:-180}"
DEADLINE=$(( $(date +%s) + TIMEOUT ))
K3S_READY=0
while [ "$(date +%s)" -lt "$DEADLINE" ]; do
  if kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml get nodes 2>/dev/null | grep -q ' Ready '; then
    K3S_READY=1
    break
  fi
  sleep 2
done

if [ "$K3S_READY" -eq 0 ]; then
  echo "musu-init: FATAL K3s never went Ready within ${TIMEOUT}s" >&2
  exit 1
fi
echo "musu-init: K3s Ready"

# ── 3.b. Ensure musu user + state dir on host rootfs (V23.3 A1.b / wiki/382) ─
# Critic C-A1b-H1 resolution: fsGroup does NOT apply to hostPath volumes, so
# we must bake ownership of /var/lib/musu/state on the host rootfs ourselves.
# Pushed to musu-init first-boot (NOT into build-musu-backend.sh step 6) to
# preserve B6 byte-identity of musu-backend.tar — chroot adduser at build
# time would touch /etc/shadow with mtime side effects.
#
# Idempotent: addgroup/adduser fail closed on re-invocation; 2>/dev/null
# absorbs the "group/user already exists" stderr. mkdir -m + chown are
# unconditional but harmless on re-run.
addgroup -g 1000 musu 2>/dev/null || true
adduser -D -u 1000 -G musu -H -s /sbin/nologin musu 2>/dev/null || true
mkdir -m 0770 -p /var/lib/musu/state
chown 1000:1000 /var/lib/musu/state

# ── 3. Wait for /etc/musu/account_key ──────────────────────────────────────
# Critic C2 (HIGH) resolution: gateway start MUST not race the B4b key write.
# Default: block forever, WARN every 30s. B4c overrides via env var.
KEY_PATH="/etc/musu/account_key"
KEY_TIMEOUT="${MUSU_KEY_WAIT_TIMEOUT_SEC:-0}"
KEY_START=$(date +%s)
LAST_WARN=0

while [ ! -f "$KEY_PATH" ]; do
  NOW=$(date +%s)
  ELAPSED=$(( NOW - KEY_START ))
  if [ "$KEY_TIMEOUT" -gt 0 ] && [ "$ELAPSED" -ge "$KEY_TIMEOUT" ]; then
    echo "musu-init: FATAL $KEY_PATH not present after ${KEY_TIMEOUT}s" >&2
    exit 2
  fi
  if [ $(( NOW - LAST_WARN )) -ge 30 ]; then
    echo "musu-init: awaiting $KEY_PATH (invoke musu-write-key from Windows side: wsl -d musu -- /usr/local/bin/musu-write-key < key.hex)"
    LAST_WARN="$NOW"
  fi
  sleep 2
done
echo "musu-init: account_key present"

# ── 3.5. Seed musu-bridge-token Secret + chmod account_key + scale Deployment
#         (V23.3 A1.b / wiki/382) ─────────────────────────────────────────────
# Composed of three sub-steps, all gated AFTER the account_key wait above:
#   (a) chmod /etc/musu/account_key to 0644 root:root so the uid-1000 musu-bridge
#       Pod can read it via hostPath subPath mount (Critic C-A1b-H4).
#   (b) Generate Opaque Secret musu-bridge-token if missing (idempotent across
#       wsl --terminate; regenerates only on full wsl --unregister) using
#       kernel CSPRNG via /dev/urandom + busybox od (Critic C-A1b-H2 — NO
#       openssl dependency, NO xxd dependency; both absent from alpine-base).
#   (c) Scale Deployment musu-bridge from 0 to 1 replicas (Critic C-A1b-H3 —
#       manifest applies at replicas:0 to avoid CrashLoopBackOff before Secret
#       + account_key chmod are both in place).
KUBECTL="kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml"

# (a) account_key chmod. World-readable inside the WSL2 distro filesystem is
# acceptable for a single-tenant operator appliance; the distro itself is
# already isolated under the Windows operator's %LOCALAPPDATA%\Packages\....
if [ -f /etc/musu/account_key ]; then
  chmod 0644 /etc/musu/account_key
fi

# (b) Secret seed. Namespace `musu` is created by the K3s manifest controller
# from musu-bridge.yaml; the namespace `apply` here is idempotent
# belt-and-suspenders for the race where the Secret is requested before the
# manifest-controller has fully applied (kubectl reports `namespaces "musu" not
# found` otherwise).
echo "musu-init: ensuring musu-bridge-token Secret exists in musu namespace"
if ! $KUBECTL -n musu get secret musu-bridge-token >/dev/null 2>&1; then
  # 64 hex chars (32 bytes × 2 hex chars) — satisfies the ≥32-char
  # MUSU_BRIDGE_TOKEN gate at musu-bridge/server.py:208-217.
  TOKEN="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
  $KUBECTL create namespace musu --dry-run=client -o yaml | $KUBECTL apply -f -
  $KUBECTL -n musu create secret generic musu-bridge-token \
    --from-literal=MUSU_BRIDGE_TOKEN="$TOKEN" \
    --dry-run=client -o yaml | $KUBECTL apply -f -
  echo "musu-init: musu-bridge-token Secret created (64-char token)"
else
  echo "musu-init: musu-bridge-token Secret already present (preserved across restart)"
fi

# (c) Scale Deployment from 0 to 1. `|| true` absorbs the transient race where
# the Deployment object hasn't been applied yet by the manifest controller —
# next musu-init invocation (or kubelet poll) will pick it up. Steady state
# after first successful boot: replicas:1 persists in K3s sqlite datastore.
echo "musu-init: scaling musu-bridge Deployment to 1 replica"
$KUBECTL -n musu scale deploy musu-bridge --replicas=1 || true

# ── 4. Start gateway ───────────────────────────────────────────────────────
echo "musu-init: starting musu-gateway"
rc-service musu-gateway start

# ── 5. Conditionally start musu-signaling (V23.4 T2-F / wiki/433 OQ-CRIT-4) ─
# Read MUSU_IS_RENDEZVOUS from /etc/musu/gateway.env. When "true", start
# musu-signaling AFTER musu-gateway is up. The `|| echo` pattern is load-
# bearing per NEW-A4 / OQ-A5: musu-init runs with `set -e` (line 22), so a
# bare `rc-service musu-signaling start` failure would propagate and stop
# the init script, leaving the user without the working gateway. Swallowing
# the failure with a WARNING line keeps gateway up even if signaling fails
# to bind. Idempotent: rc-service on an already-started service returns 0.
if [ -f /etc/musu/gateway.env ]; then
    # shellcheck disable=SC1091
    . /etc/musu/gateway.env
fi
if [ "${MUSU_IS_RENDEZVOUS:-false}" = "true" ]; then
    echo "musu-init: starting musu-signaling (rendezvous role)"
    # V23.4 T2-F audit-fix (Auditor F12 HIGH companion): emit diagnostic
    # output on failure so a broken install (e.g. missing
    # /usr/local/lib/musu-signaling/dist/signaling/user-server.js or absent
    # node_modules/{ws,express}) surfaces the failing path in the log
    # instead of silently skipping. Intent unchanged — gateway stays up;
    # failure no longer silent.
    rc-service musu-signaling start 2>&1 || {
        echo "musu-init: WARNING musu-signaling failed to start; gateway still up"
        rc-service musu-signaling status 2>&1 || true
        ls -la /usr/local/lib/musu-signaling/dist/signaling/ 2>&1 || true
        ls -la /usr/local/lib/musu-signaling/node_modules/ 2>&1 | head -20 || true
    }
fi

echo "musu-init: K3s + gateway up"
