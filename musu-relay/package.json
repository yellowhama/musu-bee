{
  "name": "musu-relay",
  "version": "0.23.4",
  "description": "Self-hostable WebRTC signaling rendezvous for musu mesh (V23.4).",
  "main": "dist/signaling/server.js",
  "scripts": {
    "dev": "ts-node src/signaling/server.ts",
    "dev:user-server": "ts-node src/signaling/user-server.ts",
    "dev:legacy-v21": "ts-node src/server.ts",
    "build": "tsc",
    "build:user-server": "tsc -p tsconfig.user-server.json",
    "start": "node dist/signaling/server.js",
    "start:user-server": "node dist/signaling/user-server.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.12",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@roamhq/wrtc": "^0.10.0"
  }
}
