# ══════════════════════════════════════════════════════════════
# MUSU 루트 환경변수 — Python 서비스 공통 설정
# 복사: cp .env.example .env  (또는 각 서비스 시작 시 export)
#
# musu-bee(Next.js) 전용 변수는 별도로 관리:
#   → musu-bee/.env.local.example 참고
#   → NEXT_PUBLIC_*, Supabase, Paddle 키는 해당 파일에만 있음
# ══════════════════════════════════════════════════════════════

# ── 인증 토큰 ─────────────────────────────────────────────────
# install.sh가 자동 생성 → ~/.musu/bridge_token 에 저장됨
# 수동 설정 시 openssl rand -hex 32 로 생성
MUSU_BRIDGE_TOKEN=your-bridge-token-here
MUSU_WORKER_TOKEN=your-worker-token-here
# 허용 Origins, 쉼표 구분 (기본: musu.pro + localhost)
MUSU_BRIDGE_ALLOWED_ORIGINS=

# ── 서비스 포트 / URL ─────────────────────────────────────────
MUSU_BRIDGE_HOST=127.0.0.1
MUSU_BRIDGE_PORT=8070
MUSU_BRIDGE_URL=http://127.0.0.1:8070

MUSU_WORKER_HOST=127.0.0.1
MUSU_WORKER_PORT=9700
MUSU_WORKER_URL=http://127.0.0.1:9700

# musu-port (WebSocket 채팅 레이어)
MUSU_PORT_HOST=127.0.0.1
MUSU_PORT=1355
MUSU_PORT_URL=http://127.0.0.1:1355
# WS 인증 토큰, MUSU_PORT_TOKEN — 미설정 시 인증 없음
MUSU_PORT_TOKEN=

# ── 데이터베이스 경로 (SQLite) ────────────────────────────────
# 상대 경로는 musu-functions 루트 기준
MUSU_DB_PATH=./data/musu.db
MUSU_TASKS_DB=./tasks.db
MUSU_WIKI_DB=./wiki.db

# ── LLM 연결 ─────────────────────────────────────────────────
# Ollama 또는 호환 API 엔드포인트
MUSU_LLM_URL=http://127.0.0.1:11434
# 모델 명시 (비워두면 MUSU_LLM_URL/v1/models 에서 자동 감지)
# MUSU_LLM_MODEL=qwen3:8b

# Claude API (musu-bridge 에이전트 라우팅에 필요)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── AI CLI 폴백 ───────────────────────────────────────────────
# 마지막 채팅 폴백으로 사용할 CLI 바이너리 (claude, codex, gemini 등)
# 비워두면 CLI 폴백 비활성화
# MUSU_AI_CLI=claude
# MUSU_AI_CLI_ARGS=--print

# ── musu-control (MCP 서버) ───────────────────────────────────
# musu-control이 musu-bridge에 연결할 때 사용
PAPERCLIP_API_URL=http://localhost:8070/api

# ── 멀티머신 / 원격 노드 ─────────────────────────────────────
# Tailscale 또는 LAN 환경에서 원격 노드 주소
# MUSU_REMOTE_NODE_URL=http://100.121.211.106:8070
# MUSU_NODE_ID=local

# ── 개발 모드 플래그 ─────────────────────────────────────────
# 1로 설정 시 토큰 검증 완화, 상세 로그 활성화
MUSU_DEV=0

# ── 채팅 제한 ─────────────────────────────────────────────────
# 서버 사이드 클라이언트별 분당 요청 제한
MUSU_CHAT_RATE_LIMIT_PER_MINUTE=20

# ══════════════════════════════════════════════════════════════
# musu-bee (Next.js 프론트엔드) 전용 변수
# → musu-bee/.env.local.example 을 복사해서 사용:
#   cp musu-bee/.env.local.example musu-bee/.env.local
#
# 포함 항목:
#   NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_PADDLE_CLIENT_TOKEN / PADDLE_API_KEY / PADDLE_WEBHOOK_SECRET
#   NEXT_PUBLIC_APP_URL
#   NEXT_PUBLIC_MUSU_WORKER_URL
# ══════════════════════════════════════════════════════════════
