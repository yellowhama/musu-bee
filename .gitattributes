# V23.3 B8 (wiki/379 §2 B8): enforce LF line endings across the project
# so that Windows git checkouts don't emit "LF will be replaced by CRLF"
# warnings on every commit, and so that musu-backend.tar contents (built
# inside Linux/WSL) match the source-tree representation byte-for-byte
# (prerequisite for B6 SOURCE_DATE_EPOCH reproducibility).

* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.go text eol=lf
*.sh text eol=lf
*.conf text eol=lf

# PowerShell — LF inside repo; PowerShell on Windows accepts both
# transparently. Installer scripts get LF in source; PSh tolerates them.
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# SQL migrations and templates
*.sql text eol=lf

# Binary artifacts — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.tar binary
*.gz binary
*.zip binary
